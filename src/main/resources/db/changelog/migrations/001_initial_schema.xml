<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd"
    logicalFilePath="db/changelog/migrations/001_initial_schema.xml">

    <changeSet id="001_create_users_table" author="mentorsys">
        <comment>Create USERS table - core user management</comment>
        <createTable tableName="users">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="password_hash" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="active" type="BOOLEAN" defaultValue="true">
                <constraints nullable="false"/>
            </column>
            <column name="online_status" type="VARCHAR(50)" defaultValue="OFFLINE">
                <constraints nullable="false"/>
            </column>
            <column name="last_activity_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValue="0"/>
        </createTable>
    </changeSet>

    <changeSet id="002_create_user_presence_events_table" author="mentorsys">
        <comment>Create USER_PRESENCE_EVENTS table for event sourcing - real-time tracking</comment>
        <createTable tableName="user_presence_events">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_presence_user" references="users(id)"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="device_type" type="VARCHAR(50)"/>
            <column name="ip_address" type="INET"/>
            <column name="session_id" type="BIGINT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="user_presence_events" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_presence_user" onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="003_create_mentors_table" author="mentorsys">
        <comment>Create MENTORS table - mentor profile information</comment>
        <createTable tableName="mentors">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" unique="true" foreignKeyName="fk_mentor_user" references="users(id)"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="bio" type="TEXT"/>
            <column name="expertise" type="TEXT[]">
                <constraints nullable="false"/>
            </column>
            <column name="hourly_rate" type="NUMERIC(10,2)"/>
            <column name="rating" type="NUMERIC(3,2)" defaultValue="0"/>
            <column name="sessions_completed" type="INT" defaultValue="0"/>
            <column name="response_time_avg" type="INT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValue="0"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="mentors" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_mentor_user" onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="004_create_mentees_table" author="mentorsys">
        <comment>Create MENTEES table - mentee profile information</comment>
        <createTable tableName="mentees">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" unique="true" foreignKeyName="fk_mentee_user" references="users(id)"/>
            </column>
            <column name="experience_level" type="VARCHAR(50)"/>
            <column name="goals" type="TEXT"/>
            <column name="learning_pace" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="mentees" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_mentee_user" onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="005_create_sessions_table" author="mentorsys">
        <comment>Create SESSIONS table - mentoring sessions</comment>
        <createTable tableName="sessions">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="mentor_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_session_mentor" references="users(id)"/>
            </column>
            <column name="mentee_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_session_mentee" references="users(id)"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="scheduled_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="duration_minutes" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="session_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="meeting_link" type="VARCHAR(500)"/>
            <column name="meeting_status" type="VARCHAR(50)"/>
            <column name="notes" type="TEXT"/>
            <column name="rating" type="INT"/>
            <column name="started_at" type="TIMESTAMP"/>
            <column name="completed_at" type="TIMESTAMP"/>
            <column name="cancelled_at" type="TIMESTAMP"/>
            <column name="cancellation_reason" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValue="0"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="sessions" baseColumnNames="mentor_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_session_mentor" onDelete="RESTRICT"/>
        <addForeignKeyConstraint baseTableName="sessions" baseColumnNames="mentee_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_session_mentee" onDelete="RESTRICT"/>
    </changeSet>

    <changeSet id="006_create_session_state_changes_table" author="mentorsys">
        <comment>Create SESSION_STATE_CHANGES table - event sourcing for session state</comment>
        <createTable tableName="session_state_changes">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="session_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_state_change_session" references="sessions(id)"/>
            </column>
            <column name="changed_by" type="BIGINT">
                <constraints foreignKeyName="fk_state_change_user" references="users(id)"/>
            </column>
            <column name="old_state" type="JSONB"/>
            <column name="new_state" type="JSONB"/>
            <column name="change_type" type="VARCHAR(50)"/>
            <column name="description" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="session_state_changes" baseColumnNames="session_id"
                                 referencedTableName="sessions" referencedColumnNames="id"
                                 constraintName="fk_state_change_session" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="session_state_changes" baseColumnNames="changed_by"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_state_change_user" onDelete="SET NULL"/>
    </changeSet>

    <changeSet id="007_create_session_messages_table" author="mentorsys">
        <comment>Create SESSION_MESSAGES table - messages in sessions</comment>
        <createTable tableName="session_messages">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="session_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_message_session" references="sessions(id)"/>
            </column>
            <column name="sender_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_message_sender" references="users(id)"/>
            </column>
            <column name="content" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="message_type" type="VARCHAR(50)" defaultValue="TEXT"/>
            <column name="attachment_url" type="VARCHAR(500)"/>
            <column name="is_edited" type="BOOLEAN" defaultValue="false"/>
            <column name="edited_at" type="TIMESTAMP"/>
            <column name="deleted_at" type="TIMESTAMP"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="session_messages" baseColumnNames="session_id"
                                 referencedTableName="sessions" referencedColumnNames="id"
                                 constraintName="fk_message_session" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="session_messages" baseColumnNames="sender_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_message_sender" onDelete="SET NULL"/>
    </changeSet>

    <changeSet id="008_create_notifications_table" author="mentorsys">
        <comment>Create NOTIFICATIONS table - real-time notifications</comment>
        <createTable tableName="notifications">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_notification_user" references="users(id)"/>
            </column>
            <column name="type" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="message" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="read" type="BOOLEAN" defaultValue="false"/>
            <column name="read_at" type="TIMESTAMP"/>
            <column name="data" type="JSONB"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMP"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="notifications" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_notification_user" onDelete="CASCADE"/>
    </changeSet>

    <changeSet id="009_create_message_delivery_log_table" author="mentorsys">
        <comment>Create MESSAGE_DELIVERY_LOG table - track notification delivery</comment>
        <createTable tableName="message_delivery_log">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>
            <column name="notification_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_delivery_notification" references="notifications(id)"/>
            </column>
            <column name="recipient_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_delivery_recipient" references="users(id)"/>
            </column>
            <column name="delivery_status" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="delivery_channel" type="VARCHAR(50)"/>
            <column name="attempt_count" type="INT" defaultValue="0"/>
            <column name="last_attempt_at" type="TIMESTAMP"/>
            <column name="delivered_at" type="TIMESTAMP"/>
            <column name="read_at" type="TIMESTAMP"/>
            <column name="error_message" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint baseTableName="message_delivery_log" baseColumnNames="notification_id"
                                 referencedTableName="notifications" referencedColumnNames="id"
                                 constraintName="fk_delivery_notification" onDelete="CASCADE"/>
        <addForeignKeyConstraint baseTableName="message_delivery_log" baseColumnNames="recipient_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_delivery_recipient" onDelete="CASCADE"/>
    </changeSet>

</databaseChangeLog>
